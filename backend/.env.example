# ============================================================================
# NEUROSHIELD — Environment Configuration
# ============================================================================
# Copy this file to .env and adjust the values for your environment.
#   cp .env.example .env
# ============================================================================

# --- Core Application ---
# APP_NAME=NeuroShield API
# APP_DESCRIPTION=Autonomous Code Security Intelligence Engine
# APP_VERSION=1.0.0

# --- Security ---
SECRET_KEY=change-this-to-a-random-secret-in-production
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Database ---
# DATABASE_URL=sqlite:///./neuroshield.db
# For PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/neuroshield

# --- Admin Seed Account (created on first start) ---
# ADMIN_EMAIL=admin@neuroshield.local
# ADMIN_PASSWORD=admin123

# --- CORS (comma-separated origins) ---
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Upload / Storage ---
# MAX_UPLOAD_SIZE_MB=10
# UPLOAD_DIR=./uploads
# REPORTS_DIR=./reports

# --- OpenAI / AI ---
# Required for AI explanations. Configure at least one provider (OpenAI, Gemini, or Groq).
# OPENAI_API_KEY=sk-your-actual-key-here
# GEMINI_API_KEY=your-gemini-key-here
# GROQ_API_KEY=your-groq-key-here
# OPENAI_MODEL=gpt-4o-mini
# AI_TEMPERATURE=0.2
# AI_MAX_TOKENS=800
# AI_TIMEOUT=8.0
# AI_AUTO_EXPLAIN_COUNT=3
# AI_MAX_WORKERS=5
# OWASP_FALLBACK_URL=https://owasp.org/www-project-top-ten/

# --- SAST Scanner ---
# BANDIT_TIMEOUT=25
# SEMGREP_TIMEOUT=60
# SEMGREP_DEFAULT_CONFIG=p/security-audit

# --- CVE Scanner ---
# OSV_API_URL=https://api.osv.dev/v1/query
# NVD_API_URL=https://services.nvd.nist.gov/rest/json/cves/2.0
# CVE_HTTP_TIMEOUT=15.0
# CVE_MAX_PACKAGES=50
# CVE_DESCRIPTION_MAX_LENGTH=500

# --- Admin ---
# ADMIN_SCAN_LIST_LIMIT=50

# --- Preview ---
# PREVIEW_FILE_LIMIT=100
